# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AQ.Ab8RN6JM_OPp3iCvXNS1-IhRP-j578WV52O6EEuIBHHoUclTWg"

# DEEPSEEK_API_KEY: Required for DeepSeek-V4-Pro AI API calls.
# Get your API key from the DeepSeek platform: https://platform.deepseek.com
# DeepSeek calls do NOT use the HTTPS_PROXY - they connect directly.
DEEPSEEK_API_Key="sk-4e91277fac3e4e99a43fe9e03c030159"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB_TOKEN: Optional GitHub Personal Access Token for higher API rate limits.
# Without this, public repo access is limited to 60 requests/hour.
# Generate at: https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN="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"

# HTTPS_PROXY: Required if Google APIs are blocked in your network (e.g., mainland China).
# This routes Gemini API calls through a proxy server. DeepSeek calls ignore this setting.
# Format: http://proxy-host:port or http://user:pass@proxy-host:port
# Example: http://127.0.0.1:7890
HTTPS_PROXY="http://127.0.0.1:10808"
